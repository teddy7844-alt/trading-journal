import { useState } from "react";

const SECTORS = [
  { name:"Technology",       etf:"XLK",  color:"#00d4ff", cycle:"Late"      },
  { name:"Healthcare",       etf:"XLV",  color:"#00ff88", cycle:"Early"     },
  { name:"Financials",       etf:"XLF",  color:"#ffaa00", cycle:"Early"     },
  { name:"Energy",           etf:"XLE",  color:"#ff6600", cycle:"Mid"       },
  { name:"Consumer Disc.",   etf:"XLY",  color:"#ff3366", cycle:"Early"     },
  { name:"Industrials",      etf:"XLI",  color:"#bb88ff", cycle:"Mid"       },
  { name:"Materials",        etf:"XLB",  color:"#44ffaa", cycle:"Mid"       },
  { name:"Utilities",        etf:"XLU",  color:"#ffdd44", cycle:"Late"      },
  { name:"Real Estate",      etf:"XLRE", color:"#ff88aa", cycle:"Late"      },
  { name:"Comm. Services",   etf:"XLC",  color:"#88ddff", cycle:"Late"      },
  { name:"Consumer Staples", etf:"XLP",  color:"#aaffdd", cycle:"Defensive" },
];
const CYCLE_ORDER = ["Early","Mid","Late","Defensive"];
const CYCLE_CFG = {
  Early:     { bg:"#001a0a", border:"#00aa44", text:"#00ff88", label:"EXPANSION"   },
  Mid:       { bg:"#0a0f00", border:"#aaaa00", text:"#ffff44", label:"PEAK"        },
  Late:      { bg:"#0a0500", border:"#aa5500", text:"#ff9900", label:"SLOWDOWN"    },
  Defensive: { bg:"#050010", border:"#5500aa", text:"#aa66ff", label:"CONTRACTION" },
};
const STEPS = ["Pulling ETF price action & volume...","Mapping institutional flow vectors...","Scoring rotation momentum...","Identifying from/to sector pairs...","Building rotation signal matrix..."];

const SC  = id => SECTORS.find(s=>s.etf===id)?.color || "#888888";
const SCL = n  => n>50?"#00ff88":n>20?"#88ff44":n>0?"#ccff44":n>-20?"#ffaa00":n>-50?"#ff6600":"#ff3366";

function PipMeter({ val, color }) {
  const f = Math.round((val/100)*10);
  return (
    <div style={{display:"flex",gap:"4px",alignItems:"center"}}>
      {Array.from({length:10}).map((_,i)=>(
        <div key={i} style={{width:"14px",height:"14px",borderRadius:"2px",border:`1px solid ${i<f?color:"#1a2a3a"}`,background:i<f?color:"#080c12",boxShadow:i<f?`0 0 5px ${color}55`:"none"}}/>
      ))}
      <span style={{fontSize:"13px",color,marginLeft:"6px",fontWeight:"700"}}>{val}%</span>
    </div>
  );
}

async function callClaude(prompt) {
  const headers = { "Content-Type":"application/json","anthropic-version":"2023-06-01","anthropic-dangerous-direct-browser-access":"true" };
  const tools = [{ type:"web_search_20250305", name:"web_search" }];
  let messages = [{ role:"user", content:prompt }];
  for (let i=0; i<8; i++) {
    const res = await fetch("https://api.anthropic.com/v1/messages",{ method:"POST", headers, body:JSON.stringify({ model:"claude-sonnet-4-20250514", max_tokens:4000, tools, messages }) });
    if (!res.ok) { const e=await res.json(); throw new Error(e.error?.message||`HTTP ${res.status}`); }
    const raw = await res.json();
    messages.push({ role:"assistant", content:raw.content });
    if (raw.stop_reason==="end_turn") {
      const text = raw.content.filter(b=>b.type==="text").map(b=>b.text).join("\n");
      const m = text.replace(/```json|```/g,"").trim().match(/\{[\s\S]*\}/);
      if (!m) throw new Error("No JSON in response");
      return JSON.parse(m[0]);
    }
    const toolUse = raw.content.filter(b=>b.type==="tool_use");
    if (!toolUse.length) {
      const text = raw.content.filter(b=>b.type==="text").map(b=>b.text).join("\n");
      const m = text.replace(/```json|```/g,"").trim().match(/\{[\s\S]*\}/);
      if (!m) throw new Error("No JSON in response");
      return JSON.parse(m[0]);
    }
    messages.push({ role:"user", content:toolUse.map(b=>({ type:"tool_result", tool_use_id:b.id, content:b.content||"" })) });
  }
  throw new Error("Max iterations reached");
}

export default function RotationFlowMap() {
  const [scanning, setScanning] = useState(false);
  const [step,     setStep]     = useState(0);
  const [progress, setProgress] = useState(0);
  const [data,     setData]     = useState(null);
  const [error,    setError]    = useState(null);

  async function runScan() {
    setScanning(true); setStep(0); setProgress(0); setData(null); setError(null);
    for (let i=0; i<STEPS.length; i++) { setStep(i); setProgress(((i+1)/STEPS.length)*100); await new Promise(r=>setTimeout(r,850)); }
    try {
      const d = await callClaude(`You are an expert sector rotation analyst for ${new Date().toLocaleDateString('en-US',{month:'long',year:'numeric'})}. Analyze where institutional money is rotating BETWEEN stock sectors right now. Return ONLY valid JSON (no markdown):
{"scanTime":"${new Date().toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'})}","phase":"EARLY CYCLE or MID CYCLE or LATE CYCLE or CONTRACTION","phaseColor":"#00ff88 or #ffff44 or #ff9900 or #aa66ff","conviction":number 0-100,"narrative":"2-3 sentences","rotationFlows":[{"fromEtf":"ETF","fromName":"name","toEtf":"ETF","toName":"name","flowBillions":number,"strength":"STRONG or MODERATE or WEAK","reason":"why","color":"#hex"}],"heatmap":[{"etf":"XLK","name":"Technology","rotationScore":number -100 to 100,"signal":"ACCUMULATE or DISTRIBUTE or HOLD or AVOID","weeklyMomentum":number,"rank":number 1-11}],"cyclePositioning":{"currentPhase":"Early or Mid or Late or Defensive","nextPhase":"Early or Mid or Late or Defensive","phaseProgress":number 0-100,"rotatingInto":["XLF"],"rotatingOutOf":["XLK"]},"keyInsight":"one sharp actionable insight"}
4-6 rotation flows. All 11 sectors in heatmap: XLK,XLV,XLF,XLE,XLY,XLI,XLB,XLU,XLRE,XLC,XLP.`);
      setData(d);
    } catch(e) { setError("Scan error: "+e.message); }
    finally { setScanning(false); }
  }

  return (
    <div style={{fontFamily:"'Courier New',monospace",background:"#070a0f",color:"#ffffff",minHeight:"100vh",fontSize:"15px"}}>
      {/* HEADER */}
      <div style={{background:"#07090e",borderBottom:"1px solid #1a2a3a",padding:"12px 20px",display:"flex",alignItems:"center",justifyContent:"space-between",gap:"10px",flexWrap:"wrap"}}>
        <div>
          <div style={{fontSize:"17px",fontWeight:"700",color:"#ffaa00",letterSpacing:"3px"}}>◈ ROTATION FLOW MAP</div>
          <div style={{fontSize:"11px",color:"#7a9aaa",letterSpacing:"2px",marginTop:"2px"}}>WHERE IS MONEY MOVING BETWEEN STOCK SECTORS</div>
        </div>
        <button onClick={runScan} disabled={scanning} style={{background:scanning?"linear-gradient(135deg,#1a0800,#2a1000)":"linear-gradient(135deg,#1a1000,#2a1800)",border:`1px solid ${scanning?"#553300":"#aa6600"}`,borderRadius:"2px",color:scanning?"#553300":"#ffaa00",fontFamily:"'Courier New',monospace",fontSize:"13px",fontWeight:"700",letterSpacing:"2px",padding:"9px 24px",cursor:scanning?"not-allowed":"pointer",textTransform:"uppercase"}}>
          {scanning?"● SCANNING...":"▶ RUN SCAN"}
        </button>
      </div>

      <div style={{padding:"16px 20px"}}>
        {scanning&&(
          <div style={{padding:"50px 20px",textAlign:"center"}}>
            {STEPS.map((s,i)=>(
              <div key={i} style={{fontSize:"14px",letterSpacing:"2px",marginBottom:"10px",color:i<step?"#2a4a5a":i===step?"#ffaa00":"#1a2a3a",fontWeight:i===step?"700":"400"}}>{i<step?"✓":i===step?"▶":"○"} {s}</div>
            ))}
            <div style={{background:"#0a1018",border:"1px solid #1a2a3a",height:"4px",margin:"20px auto",maxWidth:"380px",overflow:"hidden",borderRadius:"2px"}}>
              <div style={{height:"100%",background:"linear-gradient(90deg,#331100,#ffaa00)",width:`${progress}%`,transition:"width 0.7s ease"}}/>
            </div>
          </div>
        )}
        {error&&!scanning&&<div style={{padding:"20px",color:"#ff3366"}}>⚠ {error}</div>}
        {!scanning&&!data&&!error&&<div style={{textAlign:"center",padding:"70px 20px",color:"#2a4a5a"}}><div style={{fontSize:"38px",marginBottom:"12px",opacity:0.3}}>◈</div><div style={{fontSize:"14px",letterSpacing:"4px",textTransform:"uppercase"}}>Press Run Scan to map sector rotation flows</div></div>}

        {!scanning&&data&&(
          <>
            {/* VERDICT */}
            <div style={{background:"#080c12",border:"1px solid #1a2a3a",borderLeft:"3px solid #ffaa00",borderRadius:"3px",padding:"14px 18px",display:"flex",gap:"20px",alignItems:"flex-start",marginBottom:"14px",flexWrap:"wrap"}}>
              <div><div style={{fontSize:"11px",color:"#7a9aaa",letterSpacing:"3px",textTransform:"uppercase",marginBottom:"5px"}}>CYCLE PHASE</div><div style={{fontSize:"20px",fontWeight:"700",color:data.phaseColor,marginBottom:"6px"}}>{data.phase}</div><PipMeter val={data.conviction} color={data.phaseColor}/></div>
              <div style={{flex:1,minWidth:"180px"}}><div style={{fontSize:"11px",color:"#7a9aaa",letterSpacing:"3px",textTransform:"uppercase",marginBottom:"5px"}}>ROTATION NARRATIVE</div><div style={{fontSize:"14px",color:"#ffffff",lineHeight:"1.8"}}>{data.narrative}</div></div>
              {data.keyInsight&&<div style={{maxWidth:"220px",borderLeft:"1px solid #2a3a4a",paddingLeft:"16px"}}><div style={{fontSize:"11px",color:"#7a9aaa",letterSpacing:"3px",textTransform:"uppercase",marginBottom:"5px"}}>KEY SIGNAL</div><div style={{fontSize:"12px",color:"#ffaa00",lineHeight:"1.7"}}>{data.keyInsight}</div></div>}
            </div>

            {/* ROTATION ARROWS */}
            {data.rotationFlows?.length>0&&(
              <div style={{marginBottom:"18px"}}>
                <div style={{fontSize:"12px",color:"#7a9aaa",letterSpacing:"3px",textTransform:"uppercase",marginBottom:"10px",paddingBottom:"6px",borderBottom:"1px solid #1a2a3a"}}>ACTIVE ROTATION FLOWS · MONEY MOVING FROM → INTO</div>
                {data.rotationFlows.map((f,i)=>{
                  const fc=SC(f.fromEtf),tc=SC(f.toEtf),ac=f.color||"#ffaa00";
                  const op={STRONG:1,MODERATE:0.7,WEAK:0.4}[f.strength]||0.5;
                  return(
                    <div key={i} style={{display:"flex",alignItems:"center",marginBottom:"8px",background:"#080c12",border:"1px solid #1a2a3a",borderRadius:"3px",padding:"10px 14px",position:"relative",flexWrap:"wrap",gap:"8px"}}>
                      <div style={{position:"absolute",left:0,top:0,bottom:0,width:"3px",background:ac,opacity:0.8,borderRadius:"3px 0 0 3px"}}/>
                      <div style={{minWidth:"120px",textAlign:"center",padding:"6px 10px",borderRadius:"2px",border:`1px solid ${fc}55`,background:`${fc}11`}}>
                        <div style={{fontSize:"10px",color:`${fc}88`,marginBottom:"2px"}}>FROM</div>
                        <div style={{fontSize:"14px",fontWeight:"700",color:fc}}>{f.fromEtf}</div>
                        <div style={{fontSize:"11px",color:`${fc}cc`}}>{f.fromName}</div>
                      </div>
                      <div style={{flex:1,minWidth:"100px",display:"flex",flexDirection:"column",alignItems:"center",padding:"0 8px"}}>
                        <div style={{height:"3px",width:"100%",display:"flex",alignItems:"center"}}>
                          <div style={{flex:1,height:"3px",borderRadius:"2px",background:`linear-gradient(90deg,${fc}44,${ac},${tc}44)`,opacity:op}}/>
                          <span style={{fontSize:"14px",color:ac}}>▶</span>
                        </div>
                        <div style={{fontSize:"12px",fontWeight:"700",color:ac,marginTop:"4px"}}>~${f.flowBillions?.toFixed(1)}B/wk <span style={{opacity:0.6,fontSize:"10px"}}>{f.strength}</span></div>
                        <div style={{fontSize:"11px",color:"#8aaaaa",marginTop:"2px"}}>{f.reason}</div>
                      </div>
                      <div style={{minWidth:"120px",textAlign:"center",padding:"6px 10px",borderRadius:"2px",border:`1px solid ${tc}55`,background:`${tc}11`}}>
                        <div style={{fontSize:"10px",color:`${tc}88`,marginBottom:"2px"}}>INTO</div>
                        <div style={{fontSize:"14px",fontWeight:"700",color:tc}}>{f.toEtf}</div>
                        <div style={{fontSize:"11px",color:`${tc}cc`}}>{f.toName}</div>
                      </div>
                    </div>
                  );
                })}
              </div>
            )}

            {/* HEATMAP */}
            {data.heatmap?.length>0&&(
              <div style={{marginBottom:"18px"}}>
                <div style={{fontSize:"12px",color:"#7a9aaa",letterSpacing:"3px",textTransform:"uppercase",marginBottom:"10px",paddingBottom:"6px",borderBottom:"1px solid #1a2a3a"}}>ROTATION SCORE HEATMAP · ALL SECTORS</div>
                <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(155px,1fr))",gap:"8px"}}>
                  {[...data.heatmap].sort((a,b)=>b.rotationScore-a.rotationScore).map(s=>{
                    const col=SC(s.etf),sc=SCL(s.rotationScore),isPos=s.rotationScore>=0;
                    return(
                      <div key={s.etf} style={{background:"#080c12",border:"1px solid #1a2a3a",borderRadius:"3px",padding:"12px",position:"relative",overflow:"hidden"}}>
                        <div style={{position:"absolute",inset:0,background:col,opacity:0.05,pointerEvents:"none"}}/>
                        <div style={{position:"absolute",top:"8px",right:"10px",fontSize:"10px",color:"#4a6a7a"}}>#{s.rank}</div>
                        <div style={{fontSize:"15px",fontWeight:"700",letterSpacing:"2px",color:col,marginBottom:"2px"}}>{s.etf}</div>
                        <div style={{fontSize:"10px",color:"#7a9aaa",marginBottom:"8px"}}>{s.name}</div>
                        <div style={{fontSize:"24px",fontWeight:"700",color:sc}}>{isPos?"+":""}{s.rotationScore}</div>
                        <div style={{background:"#050810",borderRadius:"2px",height:"4px",marginTop:"7px",overflow:"hidden"}}>
                          <div style={{width:`${Math.abs(s.rotationScore)}%`,height:"100%",background:isPos?`linear-gradient(90deg,${col}44,${col})`:"linear-gradient(90deg,#ff336644,#ff3366)"}}/>
                        </div>
                        <div style={{fontSize:"10px",letterSpacing:"2px",marginTop:"6px",fontWeight:"700",color:{ACCUMULATE:"#00ff88",DISTRIBUTE:"#ff3366",HOLD:"#ffaa00",AVOID:"#ff6644"}[s.signal]||"#aaa"}}>{s.signal}</div>
                      </div>
                    );
                  })}
                </div>
              </div>
            )}

            {/* CYCLE */}
            {data.cyclePositioning&&(
              <div style={{marginBottom:"18px"}}>
                <div style={{fontSize:"12px",color:"#7a9aaa",letterSpacing:"3px",textTransform:"uppercase",marginBottom:"10px",paddingBottom:"6px",borderBottom:"1px solid #1a2a3a"}}>BUSINESS CYCLE POSITIONING</div>
                <div style={{background:"#080c12",border:"1px solid #1a2a3a",borderRadius:"3px",padding:"12px 16px",marginBottom:"10px"}}>
                  <div style={{display:"flex",justifyContent:"space-between",marginBottom:"8px"}}>
                    {CYCLE_ORDER.map(ph=><div key={ph} style={{fontSize:"11px",letterSpacing:"2px",color:ph===data.cyclePositioning.currentPhase?CYCLE_CFG[ph].text:"#3a5a6a",fontWeight:ph===data.cyclePositioning.currentPhase?"700":"400"}}>{ph===data.cyclePositioning.currentPhase?"▼ ":""}{ph.toUpperCase()}</div>)}
                  </div>
                  <div style={{background:"#050810",borderRadius:"2px",height:"7px",display:"flex",gap:"2px"}}>
                    {CYCLE_ORDER.map(ph=><div key={ph} style={{flex:1,background:ph===data.cyclePositioning.currentPhase?CYCLE_CFG[ph].text:"#0d1a24",borderRadius:"1px"}}/>)}
                  </div>
                  <div style={{display:"flex",justifyContent:"space-between",marginTop:"7px"}}>
                    <div style={{fontSize:"11px",color:"#7a9aaa"}}>PROGRESS: <span style={{color:data.phaseColor}}>{data.cyclePositioning.phaseProgress}%</span></div>
                    <div style={{fontSize:"11px",color:"#7a9aaa"}}>NEXT: <span style={{color:CYCLE_CFG[data.cyclePositioning.nextPhase]?.text||"#888"}}>{data.cyclePositioning.nextPhase?.toUpperCase()}</span></div>
                  </div>
                </div>
                <div style={{display:"grid",gridTemplateColumns:"repeat(4,1fr)",gap:"8px"}}>
                  {CYCLE_ORDER.map(phase=>{
                    const cfg=CYCLE_CFG[phase],isCurr=phase===data.cyclePositioning.currentPhase;
                    const secs=SECTORS.filter(s=>s.cycle===phase),rot=data.cyclePositioning;
                    return(
                      <div key={phase} style={{borderRadius:"3px",padding:"12px",border:`1px solid ${isCurr?cfg.border:"#1a2a3a"}`,background:isCurr?cfg.bg:"#050810",boxShadow:isCurr?`0 0 18px ${cfg.text}15`:"none"}}>
                        <div style={{fontSize:"11px",fontWeight:"700",letterSpacing:"2px",color:cfg.text,marginBottom:"2px"}}>{isCurr?"● ":"○ "}{phase.toUpperCase()}</div>
                        <div style={{fontSize:"9px",letterSpacing:"2px",color:cfg.text,marginBottom:"10px",opacity:0.8}}>{cfg.label}</div>
                        {secs.map(s=>{
                          const isIn=rot.rotatingInto?.includes(s.etf),isOut=rot.rotatingOutOf?.includes(s.etf);
                          return(
                            <div key={s.etf} style={{display:"flex",alignItems:"center",gap:"5px",marginBottom:"6px",padding:"4px 6px",background:"rgba(0,0,0,0.3)",borderRadius:"2px"}}>
                              <div style={{width:"6px",height:"6px",borderRadius:"50%",background:s.color,flexShrink:0}}/>
                              <div style={{flex:1}}><div style={{fontSize:"11px",fontWeight:"600",color:s.color}}>{s.name}</div><div style={{fontSize:"9px",color:"#6a8a7a"}}>{s.etf}</div></div>
                              {isIn&&<div style={{fontSize:"9px",fontWeight:"700",padding:"1px 5px",borderRadius:"1px",background:"#001a0a",color:"#00ff88",border:"1px solid #00aa44"}}>IN↑</div>}
                              {isOut&&<div style={{fontSize:"9px",fontWeight:"700",padding:"1px 5px",borderRadius:"1px",background:"#1a0008",color:"#ff3366",border:"1px solid #aa0033"}}>OUT↓</div>}
                            </div>
                          );
                        })}
                      </div>
                    );
                  })}
                </div>
              </div>
            )}
            <div style={{fontSize:"11px",color:"#2a4a5a",textAlign:"right",marginTop:"14px",paddingTop:"10px",borderTop:"1px solid #0d1a24"}}>◎ SCAN COMPLETED · {data.scanTime}</div>
          </>
        )}
      </div>
    </div>
  );
}
