              </>
            )}
            {tab===3&&(
              <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(220px,1fr))",gap:"10px"}}>
                {data.macro?.map(m=>(
                  <div key={m.metric} style={card}>
                    <div style={{fontSize:"11px",color:"#8aaacc",marginBottom:"4px"}}>{m.metric}</div>
                    <div style={{fontSize:"24px",fontWeight:"700",color:m.direction==="up"?"#ff6644":m.direction==="down"?"#00ff88":"#ffffff"}}>{m.value}</div>
                    <div style={{fontSize:"13px",marginTop:"4px",color:m.direction==="up"?"#ff6644":m.direction==="down"?"#00ff88":"#8aaacc"}}>{m.direction==="up"?"▲":m.direction==="down"?"▼":"—"} {m.change}</div>
                    <div style={{fontSize:"12px",color:"#ccdde8",marginTop:"8px",lineHeight:"1.6"}}>{m.note}</div>
                  </div>
                ))}
              </div>
            )}
            <div style={{fontSize:"11px",color:"#4a7a9a",marginTop:"16px",textAlign:"right"}}>◎ {data.scanTime}</div>
          </div>
        </>
      )}
    </div>
  );
}
