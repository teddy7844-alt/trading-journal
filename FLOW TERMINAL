All 11 sectors: XLK,XLV,XLF,XLE,XLY,XLI,XLB,XLU,XLRE,XLC,XLP. All 5 crypto: BTC,ETH,SOL,XRP,ALT.`);
      setData(d);
    } catch(e) { setError("Scan failed: "+e.message); }
    finally { setScanning(false); }
  }

  const sm={}, cm={};
  data?.sectors?.forEach(s=>sm[s.etf]=s);
  data?.crypto?.forEach(c=>cm[c.ticker]=c);
  const card = { background:"#0a1420", border:"1px solid #1a3a5a", borderRadius:"3px", padding:"16px", position:"relative", overflow:"hidden" };

