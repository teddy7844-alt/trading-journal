    <div style={{fontFamily:"'Courier New',monospace",background:"#080c10",color:"#ffffff",minHeight:"100vh",fontSize:"15px"}}>
      {/* HEADER */}
      <div style={{background:"#0a1420",borderBottom:"1px solid #1a3a5a",padding:"12px 20px",display:"flex",alignItems:"center",justifyContent:"space-between",gap:"10px",flexWrap:"wrap"}}>
        <div>
          <div style={{fontSize:"17px",fontWeight:"700",color:"#00d4ff",letterSpacing:"3px"}}>⬡ SECTOR ROTATION TERMINAL</div>
          <div style={{fontSize:"11px",color:"#8aaacc",letterSpacing:"2px",marginTop:"2px"}}>MONEY FLOW · INSTITUTIONAL POSITIONING · MACRO REGIME</div>
        </div>
        <div style={{display:"flex",alignItems:"center",gap:"10px"}}>
          {data&&<div style={{background:"#001a2a",border:"1px solid #003a5a",borderRadius:"2px",padding:"4px 10px",fontSize:"11px",color:"#00aaff",letterSpacing:"2px"}}>● LIVE</div>}
          <button onClick={runScan} disabled={scanning} style={{background:scanning?"linear-gradient(135deg,#330011,#440022)":"linear-gradient(135deg,#003366,#004488)",border:`1px solid ${scanning?"#aa0044":"#0066aa"}`,borderRadius:"3px",color:scanning?"#ff3366":"#00d4ff",fontFamily:"'Courier New',monospace",fontSize:"13px",fontWeight:"700",letterSpacing:"2px",padding:"9px 24px",cursor:scanning?"not-allowed":"pointer",textTransform:"uppercase"}}>
            {scanning?"● SCANNING...":"▶ RUN SCAN"}
          </button>
        </div>
      </div>

      {/* LOADING */}
      {scanning&&(
        <div style={{padding:"50px 20px",textAlign:"center"}}>
          {STEPS.map((s,i)=>(
            <div key={i} style={{fontSize:"14px",letterSpacing:"2px",marginBottom:"10px",color:i<step?"#3a5a6a":i===step?"#00d4ff":"#1a3a5a",fontWeight:i===step?"700":"400"}}>{i<step?"✓":i===step?"▶":"○"} {s}</div>
          ))}
          <div style={{background:"#0a1420",border:"1px solid #1a3a5a",height:"5px",margin:"22px auto",maxWidth:"400px",overflow:"hidden",borderRadius:"2px"}}>
            <div style={{background:"linear-gradient(90deg,#003a6a,#00d4ff)",height:"100%",width:`${progress}%`,transition:"width 0.6s ease"}}/>
          </div>
        </div>
      )}
      {error&&!scanning&&<div style={{padding:"20px",color:"#ff3366"}}>⚠ {error}</div>}
      {!scanning&&!data&&!error&&<div style={{textAlign:"center",padding:"70px 20px",color:"#4a7a9a"}}><div style={{fontSize:"38px",marginBottom:"12px",opacity:0.4}}>⬡</div><div style={{fontSize:"14px",letterSpacing:"3px",textTransform:"uppercase"}}>Press Run Scan to analyze market flows</div></div>}

      {/* DATA */}
      {!scanning&&data&&(
        <>
          <div style={{padding:"14px 20px 0"}}>
            <div style={{background:"#0a1420",border:"1px solid #1a3a5a",borderRadius:"3px",padding:"16px 20px",marginBottom:"12px",display:"flex",alignItems:"center",gap:"20px",flexWrap:"wrap"}}>
              <div><div style={{fontSize:"11px",color:"#8aaacc",letterSpacing:"2px",textTransform:"uppercase",marginBottom:"4px"}}>MARKET REGIME</div><div style={{fontSize:"20px",fontWeight:"700",color:data.verdict.color}}>{data.verdict.regime}</div></div>
              <div style={{flex:1}}><div style={{fontSize:"11px",color:"#8aaacc",letterSpacing:"2px",textTransform:"uppercase",marginBottom:"4px"}}>VERDICT</div><div style={{fontSize:"14px",color:"#ffffff",lineHeight:"1.5"}}>{data.verdict.summary}</div></div>
              <div><div style={{fontSize:"11px",color:"#8aaacc",letterSpacing:"2px",textTransform:"uppercase",marginBottom:"4px"}}>CONVICTION</div><PipMeter val={data.verdict.conviction} color={data.verdict.color}/></div>
            </div>
            {data.narrative&&<div style={{background:"#070b12",border:"1px solid #1a3a5a",borderRadius:"3px",padding:"12px 16px",fontSize:"14px",lineHeight:"1.8",color:"#ffffff",marginBottom:"12px"}}>{data.narrative}</div>}
          </div>
          <div style={{display:"flex",borderBottom:"1px solid #1a3a5a",padding:"0 20px",overflowX:"auto"}}>
            {TABS.map((t,i)=>(
              <button key={t} onClick={()=>setTab(i)} style={{padding:"10px 18px",cursor:"pointer",fontSize:"13px",letterSpacing:"2px",textTransform:"uppercase",color:tab===i?"#00d4ff":"#6a9aaa",background:"none",border:"none",borderBottom:tab===i?"2px solid #00d4ff":"2px solid transparent",fontFamily:"'Courier New',monospace",whiteSpace:"nowrap"}}>{t}</button>
            ))}
          </div>
          <div style={{padding:"16px 20px"}}>
            {tab===0&&(
              <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(280px,1fr))",gap:"10px"}}>
                {SECTORS.map(sec=>{const d=sm[sec.etf];if(!d)return null;const isIn=d.weeklyFlow>0;return(
                  <div key={sec.etf} style={card}>
                    <div style={{position:"absolute",top:0,left:0,width:"3px",height:"100%",background:sec.color}}/>
                    <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start",marginBottom:"10px"}}>
                      <div><div style={{fontSize:"14px",fontWeight:"700",color:"#ffffff"}}>{sec.name}</div><div style={{fontSize:"12px",color:"#8aaacc",marginTop:"2px"}}>{sec.etf}</div></div>
                      <div style={biasStyle(d.bias)}>{d.bias}</div>
                    </div>
                    <div style={{display:"flex",justifyContent:"space-between",marginBottom:"6px"}}><span style={{fontSize:"12px",color:"#8aaacc"}}>WEEKLY FLOW</span><span style={{fontSize:"15px",fontWeight:"700",color:isIn?"#00ff88":"#ff3366"}}>{isIn?"+":""}${d.weeklyFlow?.toFixed(1)}B</span></div>
                    <div style={{height:"4px",borderRadius:"2px",marginBottom:"8px",background:"#0d1a28",overflow:"hidden"}}><div style={{width:`${Math.min(100,(Math.abs(d.weeklyFlow)/5)*100)}%`,height:"100%",background:isIn?"#00ff88":"#ff3366"}}/></div>
                    <div style={{display:"flex",justifyContent:"space-between",marginBottom:"5px"}}><span style={{fontSize:"12px",color:"#8aaacc"}}>INST. POS.</span><span style={{fontSize:"13px",color:"#ffffff"}}>{d.instPos}</span></div>
                    <div style={{display:"flex",justifyContent:"space-between"}}><span style={{fontSize:"12px",color:"#8aaacc"}}>MOMENTUM</span><span style={{fontSize:"13px",color:d.momentum>0?"#00ff88":"#ff3366"}}>{d.momentum>0?"↑":"↓"} {Math.abs(d.momentum)}%</span></div>
