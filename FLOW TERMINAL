                <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(260px,1fr))",gap:"10px"}}>
                  {CRYPTO.map(coin=>{const d=cm[coin.ticker];if(!d)return null;const isIn=d.weeklyFlow>0;const cols={BTC:"#f7931a",ETH:"#627eea",SOL:"#9945ff",XRP:"#346aa9",ALT:"#00ffcc"};return(
                    <div key={coin.ticker} style={card}>
                      <div style={{position:"absolute",top:0,left:0,width:"3px",height:"100%",background:cols[coin.ticker]}}/>
                      <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start",marginBottom:"10px"}}>
                        <div><div style={{fontSize:"16px",fontWeight:"700",color:cols[coin.ticker]}}>{coin.ticker}</div><div style={{fontSize:"12px",color:"#8aaacc",marginTop:"2px"}}>{coin.name}</div></div>
                        <div style={biasStyle(d.bias)}>{d.bias}</div>
                      </div>
                      <div style={{display:"flex",justifyContent:"space-between",marginBottom:"6px"}}><span style={{fontSize:"12px",color:"#8aaacc"}}>WEEKLY FLOW</span><span style={{fontSize:"15px",fontWeight:"700",color:isIn?"#00ff88":"#ff3366"}}>{isIn?"+":""}${d.weeklyFlow?.toFixed(1)}B</span></div>
                      <div style={{height:"4px",borderRadius:"2px",marginBottom:"8px",background:"#0d1a28",overflow:"hidden"}}><div style={{width:`${Math.min(100,(Math.abs(d.weeklyFlow)/3)*100)}%`,height:"100%",background:isIn?"#00ff88":"#ff3366"}}/></div>
                      {d.note&&<div style={{fontSize:"12px",color:"#ccdde8",lineHeight:"1.6"}}>{d.note}</div>}
                    </div>
                  );})}
