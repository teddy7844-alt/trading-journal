function biasStyle(b) {
  return { borderRadius:"2px", padding:"3px 10px", fontSize:"11px", fontWeight:"700", letterSpacing:"2px", display:"inline-block",
    background:b==="BULLISH"?"#001a0a":b==="BEARISH"?"#1a0008":"#0a0a1a",
    color:b==="BULLISH"?"#00ff88":b==="BEARISH"?"#ff3366":"#aaaaff",
    border:`1px solid ${b==="BULLISH"?"#00aa44":b==="BEARISH"?"#aa0033":"#4444aa"}` };
}
function PipMeter({ val, color }) {
  const f = Math.round((val/100)*10);
  return (
    <div style={{display:"flex",gap:"4px",alignItems:"center"}}>
      {Array.from({length:10}).map((_,i)=>(
        <div key={i} style={{width:"15px",height:"15px",borderRadius:"2px",border:`1px solid ${i<f?color:"#1a3a5a"}`,background:i<f?color:"#0a1420",boxShadow:i<f?`0 0 6px ${color}55`:"none"}}/>
      ))}
      <span style={{fontSize:"14px",color,marginLeft:"7px",fontWeight:"700"}}>{val}%</span>
    </div>
  );
}

async function callClaude(prompt) {
  const headers = { "Content-Type":"application/json","anthropic-version":"2023-06-01","anthropic-dangerous-direct-browser-access":"true" };
  const tools = [{ type:"web_search_20250305", name:"web_search" }];
  let messages = [{ role:"user", content:prompt }];
  for (let i=0; i<8; i++) {
    const res = await fetch("https://api.anthropic.com/v1/messages",{ method:"POST", headers, body:JSON.stringify({ model:"claude-sonnet-4-20250514", max_tokens:4000, tools, messages }) });
    if (!res.ok) { const e=await res.json(); throw new Error(e.error?.message||`HTTP ${res.status}`); }
    const raw = await res.json();
    messages.push({ role:"assistant", content:raw.content });
    if (raw.stop_reason==="end_turn") {
      const text = raw.content.filter(b=>b.type==="text").map(b=>b.text).join("\n");
      const m = text.replace(/```json|```/g,"").trim().match(/\{[\s\S]*\}/);
      if (!m) throw new Error("No JSON in response");
      return JSON.parse(m[0]);
    }
    const toolUse = raw.content.filter(b=>b.type==="tool_use");
    if (!toolUse.length) {
      const text = raw.content.filter(b=>b.type==="text").map(b=>b.text).join("\n");
      const m = text.replace(/```json|```/g,"").trim().match(/\{[\s\S]*\}/);
      if (!m) throw new Error("No JSON in response");
      return JSON.parse(m[0]);
    }
    messages.push({ role:"user", content:toolUse.map(b=>({ type:"tool_result", tool_use_id:b.id, content:b.content||"" })) });
  }
  throw new Error("Max iterations reached");
}

export default function SectorTerminal() {
  const [tab,      setTab]      = useState(0);
  const [scanning, setScanning] = useState(false);
